{
  "app_name": "single-piece-client",
  "site_id": "hz_demo",
  "device_id": "spc_01",
  "selected_algorithm": "default_algorithm",
  "ui_refresh_ms": 1000,
  "log_level": "INFO",
  "ingest": {
    "enabled_channels": ["file", "tcp", "http", "unix_socket", "zeromq"],
    "file": {
      "enabled": true,
      "watch_mode": "directory",
      "path": "./runtime/hz_demo/spc_01/realtime",
      "file_pattern": "*.jsonl",
      "recursive": false,
      "parser_type": "jsonl_default"
    },
    "tcp": {
      "enabled": true,
      "host": "127.0.0.1",
      "port": 9101,
      "message_mode": "line",
      "parser_type": "tcp_json_default"
    },
    "http": {
      "enabled": true,
      "host": "127.0.0.1",
      "port": 9102,
      "endpoint": "/events",
      "parser_type": "http_json_default"
    },
    "unix_socket": {
      "enabled": true,
      "path": "/tmp/single_piece_algo.sock",
      "socket_type": "stream",
      "parser_type": "unix_json_default"
    },
    "zeromq": {
      "enabled": true,
      "mode": "pull",
      "endpoint": "tcp://127.0.0.1:5555",
      "topic": "",
      "parser_type": "zmq_json_default"
    }
  },
  "monitor": {
    "enabled": true,
    "sample_interval_ms": 1000,
    "monitor_cpu": true,
    "monitor_memory": true,
    "monitor_disk": true
  }
}
